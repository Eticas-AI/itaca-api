# ITACA API — environment variable contract
#
# Copy to `.env` and adjust. Everything a deployment operator needs to
# change lives here; no code or image changes should ever be required.
# The variables under "Auth" are the ones to repoint when moving from
# local testing to a shared deployment (e.g. the DataPACT environment).

# --- API ---
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
# Comma-separated list of allowed origins. "*" only for development.
CORS_ORIGINS=*

# --- Storage ---
# Inside the provided Docker image these default to /data/datasets and
# /data/results (mounted as a volume). Override for bare-metal runs.
DATA_DIR=data/datasets
RESULTS_DIR=data/results
MAX_UPLOAD_MB=200

# --- Auth ---
# false = no authentication (local development without Keycloak).
AUTH_ENABLED=true
# For the local dev Keycloak from `docker compose --profile dev up`,
# use http://keycloak:8080 (from inside the compose network) or
# http://localhost:8081 (from the host).
# → Deployment: point these three at your Keycloak instance
# (in DataPACT: the consortium's shared Keycloak).
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=datapact-dev
KEYCLOAK_CLIENT_ID=itaca-api
# Set to false only if your Keycloak does not stamp the client id
# in the token audience.
KEYCLOAK_VERIFY_AUD=true
